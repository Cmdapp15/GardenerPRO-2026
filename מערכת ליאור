function ExpensesView({ expenses, setExpenses }) {
  const [expenseName, setExpenseName] = useState('');
  const [expenseCost, setExpenseCost] = useState('');
  const [expenseCategory, setExpenseCategory] = useState('כלים');
  const [expenseDate, setExpenseDate] = useState(new Date().toISOString().split('T')[0]);

  const handleAddExpense = (e) => {
    e.preventDefault();
    if (!expenseName || !expenseCost) return;
    
    const newExp = {
      id: Date.now(),
      name: expenseName,
      cost: Number(expenseCost),
      category: expenseCategory,
      date: expenseDate
    };

    setExpenses([newExp, ...expenses]);
    setExpenseName('');
    setExpenseCost('');
  };

  const handleDeleteExpense = (id) => {
    setExpenses(expenses.filter(e => e.id !== id));
  };

  return (
    <div className="bg-white/5 border border-white/10 rounded-3xl p-6 backdrop-blur-xl space-y-6 animate-in fade-in duration-300">
      <div>
        <h2 className="text-lg font-black text-white">ניהול הוצאות כלים ורכש חיצוני</h2>
        <p className="text-xs opacity-60">תיעוד של כל הכלים, דלק, וחומרי דישון שרכשת בנפרד ללא קשר לחשבון הלקוח.</p>
      </div>

      {/* Add Expense Form */}
      <form onSubmit={handleAddExpense} className="bg-black/30 p-4 rounded-2xl border border-white/5 grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div>
          <label className="block text-xs opacity-60 mb-1">שם הכלי / החומר</label>
          <input 
            type="text" 
            required
            value={expenseName} 
            onChange={e => setExpenseName(e.target.value)}
            placeholder="למשל: מפוח עלים"
            className="w-full bg-black/40 border border-white/10 rounded-xl p-2 text-xs focus:outline-none"
          />
        </div>
        <div>
          <label className="block text-xs opacity-60 mb-1">עלות (₪)</label>
          <input 
            type="number" 
            required
            value={expenseCost} 
            onChange={e => setExpenseCost(e.target.value)}
            className="w-full bg-black/40 border border-white/10 rounded-xl p-2 text-xs focus:outline-none"
          />
        </div>
        <div>
          <label className="block text-xs opacity-60 mb-1">קטגוריה</label>
          <select 
            value={expenseCategory} 
            onChange={e => setExpenseCategory(e.target.value)}
            className="w-full bg-black/40 border border-white/10 rounded-xl p-2 text-xs focus:outline-none"
          >
            <option value="כלים">כלים ומכונות</option>
            <option value="חומרים">חומרי דישון והשקייה</option>
            <option value="שוטף">דלק ונסיעות</option>
          </select>
        </div>
        <button 
          type="submit" 
          className="py-2.5 bg-[#70892E] hover:bg-[#5b7024] text-white rounded-xl text-xs font-bold transition-all"
        >
          הוסף הוצאה לרשימה
        </button>
      </form>

      {/* Expense List Table */}
      <div className="space-y-2">
        <h3 className="font-bold text-xs opacity-85">הוצאות שתועדו השנה</h3>
        <div className="space-y-2 max-h-80 overflow-y-auto">
          {expenses.map(exp => (
            <div key={exp.id} className="bg-black/20 p-3 rounded-xl border border-white/5 flex justify-between items-center text-xs">
              <div>
                <p className="font-bold">{exp.name}</p>
                <p className="text-[10px] opacity-50">{exp.date} • {exp.category}</p>
              </div>
              <div className="flex items-center gap-3">
                <span className="font-bold text-[#70892E]">₪{exp.cost}</span>
                <button 
                  onClick={() => handleDeleteExpense(exp.id)}
                  className="text-red-400 hover:text-red-300 p-1"
                >
                  <Trash2 size={14}/>
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
