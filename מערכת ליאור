  LayoutDashboard, Users, Plus, ChevronRight, MapPin, Phone, MessageCircle, 
  TrendingUp, Calendar, AlertCircle, X, Wrench, Search, DollarSign, Clock, 
  BarChart3, Edit3, Trash2, Check, CheckCircle2, AlertTriangle, UserPlus, Info, Save, Image, Smartphone
} from 'lucide-react';

const INITIAL_CLIENTS = [
  { 
