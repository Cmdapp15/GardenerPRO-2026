    relationshipNotes: 'שרון מאוד פדנט לגבי פינוי הגזם. תמיד לדאוג שהכל יהיה מטאטא נקי.',
    lastVisitDate: '2026-05-15',
    images: ['https://images.unsplash.com/photo-1584467541268-b040f83be3fd?w=400&auto=format&fit=crop&q=60'],
    visits: [
      { id: 201, date: '2026-05-15', jobType: 'עיצוב עצים ופיסול שיחים', cost: 1200, paymentType: 'צק', paid: true, details: 'שולמו 1200 ש"ח בצק שייפרע בסוף החודש.' },
      { id: 202, date: '2026-05-08', jobType: 'הקמת ערוגות חדשות', cost: 3200, paymentType: 'העברה', paid: true, details: 'התקנת מערכת טפטפות חדשה ושתילת 40 שתילי פרחים.' }
    ]
  },
  { 
    id: 3, 
    name: 'דניאל קליין', 
    phone: '0528889900', 
    location: 'תל אביב, בזל 12', 
    age: 29,
    gardenSize: 45, 
    profitRating: 5, 
    headacheRating: 5, 
    status: 'potential',
    frequency: 30, 
    notes: 'מרפסת גג גדולה. להתחשב בשכנים מלמטה כשמשקים.',
    relationshipNotes: 'התלונן פעם אחת על לכלוך במעלית. חשוב להיות סופר אדיבים.',
    lastVisitDate: '2026-03-01',
    images: [],
    visits: []
  }
];

const INITIAL_EXPENSES = [
  { id: 1, name: 'מפוח עלים בנזין מקיטה', cost: 1850, date: '2026-04-10', category: 'כלים' },
  { id: 2, name: 'שקי דשן כימי (מלאי קיץ)', cost: 600, date: '2026-05-02', category: 'חומרים' },
  { id: 3, name: 'דלק לגזם ומכסחת', cost: 220, date: '2026-05-18', category: 'שוטף' }
];

export default function App() {
  const [clients, setClients] = useState(INITIAL_CLIENTS);
  const [expenses, setExpenses] = useState(INITIAL_EXPENSES);
  const [activeTab, setActiveTab] = useState('dashboard'); // dashboard, clients, tools, analytics
  const [selectedClientId, setSelectedClientId] = useState(null);
  const [searchQuery, setSearchQuery] = useState('');
  
  // Modals / Editors State
  const [isAddClientOpen, setIsAddClientOpen] = useState(false);
  const [isAddVisitOpen, setIsAddVisitOpen] = useState(false);
  const [isEditVisitOpen, setIsEditVisitOpen] = useState(false);
  const [activeVisitToEdit, setActiveVisitToEdit] = useState(null);

  // New Client Form State
  const [newClient, setNewClient] = useState({
    name: '', phone: '', location: '', age: 35, gardenSize: 100,
    profitRating: 7, headacheRating: 2, status: 'active', frequency: 14,
    notes: '', relationshipNotes: '', images: [], visits: []
  });

  // New Visit Form State
  const [newVisit, setNewVisit] = useState({
    date: new Date().toISOString().split('T')[0],
    jobType: 'תחזוקה שוטפת',
    cost: '',
    paymentType: 'העברה',
    paid: false,
    details: ''
  });

  // Global Goal
  const annualGoal = 250000;

  // Selected client memoized
  const selectedClient = useMemo(() => {
    return clients.find(c => c.id === selectedClientId);
  }, [clients, selectedClientId]);

  const handleAddClient = (e) => {
    e.preventDefault();
    if (!newClient.name || !newClient.phone) return;
    const clientToAdd = {
      ...newClient,
      id: Date.now(),
      lastVisitDate: '',
      visits: []
    };
    setClients([clientToAdd, ...clients]);
    setNewClient({
      name: '', phone: '', location: '', age: 35, gardenSize: 100,
      profitRating: 7, headacheRating: 2, status: 'active', frequency: 14,
      notes: '', relationshipNotes: '', images: [], visits: []
    });
    setIsAddClientOpen(false);
    setActiveTab('clients');
  };

  const handleAddVisit = (e) => {
    e.preventDefault();
    if (!selectedClientId) return;
    
    const visitToAdd = {
      id: Date.now(),
      date: newVisit.date,
      jobType: newVisit.jobType,
      cost: Number(newVisit.cost) || 0,
      paymentType: newVisit.paymentType,
      paid: newVisit.paid,
      details: newVisit.details
    };

    setClients(prevClients => {
      return prevClients.map(c => {
        if (c.id === selectedClientId) {
          const updatedVisits = [visitToAdd, ...c.visits];
          // Automatically update last visit date to the newest visit's date
          const sortedVisits = [...updatedVisits].sort((a,b) => new Date(b.date) - new Date(a.date));
          return {
            ...c,
            visits: updatedVisits,
            lastVisitDate: sortedVisits[0] ? sortedVisits[0].date : c.lastVisitDate
          };
        }
        return c;
      });
    });

    setNewVisit({
      date: new Date().toISOString().split('T')[0],
      jobType: 'תחזוקה שוטפת',
      cost: '',
      paymentType: 'העברה',
      paid: false,
      details: ''
    });
    setIsAddVisitOpen(false);
  };

  const handleTogglePaymentStatus = (clientId, visitId) => {
    setClients(prevClients => {
      return prevClients.map(c => {
        if (c.id === clientId) {
          return {
            ...c,
            visits: c.visits.map(v => v.id === visitId ? { ...v, paid: !v.paid } : v)
          };
        }
        return c;
      });
    });
  };

  const handleOpenEditVisit = (visit) => {
    setActiveVisitToEdit({ ...visit });
    setIsEditVisitOpen(true);
  };

  const handleSaveEditedVisit = (e) => {
    e.preventDefault();
    if (!selectedClientId || !activeVisitToEdit) return;

    setClients(prevClients => {
      return prevClients.map(c => {
        if (c.id === selectedClientId) {
          const updatedVisits = c.visits.map(v => v.id === activeVisitToEdit.id ? activeVisitToEdit : v);
          const sortedVisits = [...updatedVisits].sort((a,b) => new Date(b.date) - new Date(a.date));
          return {
            ...c,
            visits: updatedVisits,
            lastVisitDate: sortedVisits[0] ? sortedVisits[0].date : c.lastVisitDate
          };
        }
        return c;
      });
    });

    setIsEditVisitOpen(false);
    setActiveVisitToEdit(null);
  };

  const handleDeleteVisit = (clientId, visitId) => {
    if(!window.confirm("האם אתה בטוח שברצונך למחוק את התיעוד של ביקור זה?")) return;
    setClients(prevClients => {
      return prevClients.map(c => {
        if (c.id === clientId) {
          const updatedVisits = c.visits.filter(v => v.id !== visitId);
          const sortedVisits = [...updatedVisits].sort((a,b) => new Date(b.date) - new Date(a.date));
          return {
            ...c,
            visits: updatedVisits,
            lastVisitDate: sortedVisits[0] ? sortedVisits[0].date : ''
          };
        }
        return c;
      });
    });
  };

  const handleUpdateNotes = (clientId, type, text) => {
    setClients(prevClients => {
      return prevClients.map(c => {
        if (c.id === clientId) {
          return {
            ...c,
            [type]: text
          };
        }
        return c;
      });
    });
  };

  const handleSimulatePhotoUpload = (clientId) => {
    const urls = [
      'https://images.unsplash.com/photo-1592150621744-aca64f48394a?w=400&auto=format&fit=crop&q=60',
      'https://images.unsplash.com/photo-1598902108854-10e335adac99?w=400&auto=format&fit=crop&q=60',
      'https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=400&auto=format&fit=crop&q=60'
    ];
    const randomUrl = urls[Math.floor(Math.random() * urls.length)];
    setClients(prevClients => {
      return prevClients.map(c => {
        if (c.id === clientId) {
          return {
            ...c,
            images: [randomUrl, ...c.images]
          };
        }
        return c;
      });
    });
  };

  const handleUpdateFrequency = (clientId, newFreq) => {
    setClients(prevClients => {
      return prevClients.map(c => {
        if (c.id === clientId) {
          return { ...c, frequency: Number(newFreq) };
        }
        return c;
      });
    });
  };

  // Financial Computations for Charts & Dashboard
  const totalRevenue = useMemo(() => {
    return clients.reduce((sum, c) => sum + c.visits.reduce((vSum, v) => vSum + v.cost, 0), 0);
  }, [clients]);

  const totalPaidRevenue = useMemo(() => {
    return clients.reduce((sum, c) => sum + c.visits.reduce((vSum, v) => vSum + (v.paid ? v.cost : 0), 0), 0);
  }, [clients]);

  const totalUnpaidRevenue = totalRevenue - totalPaidRevenue;

  const totalExpenses = useMemo(() => {
    return expenses.reduce((sum, e) => sum + e.cost, 0);
  }, [expenses]);

  const netProfit = totalRevenue - totalExpenses;

  // Overdue action checks (Automated alerts: last visit compared to preferred connection frequency)
  const clientsWithAlerts = useMemo(() => {
    return clients.map(c => {
      if (!c.lastVisitDate) return { ...c, alertLevel: 'red', daysOverdue: 999 };
      const last = new Date(c.lastVisitDate);
      const today = new Date();
      const diffTime = Math.abs(today - last);
      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
      
      let alertLevel = 'green';
      if (diffDays > c.frequency * 1.5) {
        alertLevel = 'red';
      } else if (diffDays > c.frequency) {
        alertLevel = 'yellow';
      }
      return {
        ...c,
        alertLevel,
        daysOverdue: Math.max(0, diffDays - c.frequency)
      };
    });
  }, [clients]);

  return (
    <div dir="rtl" className="min-h-screen bg-[#02211c] text-white font-sans overflow-x-hidden selection:bg-[#70892E]/50 pb-24">
      {/* Background Orbs */}
      <div className="fixed inset-0 pointer-events-none overflow-hidden z-0">
        <div className="absolute top-[-20%] right-[-10%] w-[600px] h-[600px] bg-[#70892E]/10 rounded-full blur-[130px]" />
        <div className="absolute bottom-[-10%] left-[-10%] w-[500px] h-[500px] bg-emerald-950/40 rounded-full blur-[110px]" />
      </div>

      {/* Header Panel */}
      <header className="sticky top-0 bg-[#053931]/60 backdrop-blur-2xl p-4 border-b border-white/10 z-40 flex justify-between items-center transition-all">
        <div>
          <div className="flex items-center gap-2">
            <div className="w-3 h-3 rounded-full bg-[#70892E] animate-ping" />
            <h1 className="text-xl font-black tracking-tight text-white">Gardener<span className="text-[#70892E]">PRO</span> <span className="text-[11px] font-medium opacity-60">v2.0</span></h1>
          </div>
          <p className="text-[10px] uppercase tracking-widest text-[#70892E] font-bold">הקוקפיט הניהולי של ליאור</p>
        </div>

        <div className="flex items-center gap-3">
          <button 
            onClick={() => setIsAddClientOpen(true)}
            className="flex items-center gap-2 px-3 py-1.5 bg-[#70892E] hover:bg-[#5b7024] text-white rounded-xl text-xs font-bold transition-all shadow-lg shadow-[#70892E]/20 active:scale-95"
          >
            <UserPlus size={14} />
            <span>לקוח חדש</span>
          </button>
          <div className="w-9 h-9 rounded-full bg-[#70892E]/20 border border-[#70892E]/40 flex items-center justify-center font-bold text-[#70892E] shadow-inner text-sm">
            ל
          </div>
        </div>
      </header>

      {/* Main Container */}
      <main className="relative z-10 max-w-6xl mx-auto p-4 space-y-6">
        
        {/* Quick Alarm Banner (If there are clients needing immediate touchpoint) */}
        {clientsWithAlerts.some(c => c.alertLevel === 'red') && (
          <div className="bg-red-500/10 border border-red-500/20 backdrop-blur-md rounded-2xl p-4 flex items-center justify-between gap-4 animate-pulse">
            <div className="flex items-center gap-3 text-red-200">
              <AlertCircle className="text-red-400 shrink-0" size={20} />
              <div>
                <p className="text-xs font-bold">מערכת התראות מבוססת זמן עבודה ותדירות:</p>
                <p className="text-[11px] opacity-80">יש לקוחות שעברו את התדירות המומלצת שהגדרת. התקשר לשמר אותם!</p>
              </div>
            </div>
            <button 
              onClick={() => { setActiveTab('clients'); setSearchQuery(''); }}
              className="px-3 py-1 bg-red-500/20 hover:bg-red-500/30 text-red-200 text-xs font-bold rounded-lg transition-all"
            >
              הצג לקוחות דחופים
            </button>
          </div>
        )}

        {/* Tab Selector Desktop-Friendly Header */}
        <div className="hidden md:flex justify-start gap-4 p-1 bg-black/20 rounded-2xl max-w-md border border-white/5">
          <button onClick={() => { setActiveTab('dashboard'); setSelectedClientId(null); }} className={`flex-1 py-2 text-center rounded-xl text-xs font-bold transition-all ${activeTab === 'dashboard' ? 'bg-[#70892E] text-white' : 'opacity-60 hover:opacity-100'}`}>בורסת העסק</button>
          <button onClick={() => { setActiveTab('clients'); }} className={`flex-1 py-2 text-center rounded-xl text-xs font-bold transition-all ${activeTab === 'clients' ? 'bg-[#70892E] text-white' : 'opacity-60 hover:opacity-100'}`}>אנשי קשר ונכסים</button>
          <button onClick={() => { setActiveTab('analytics'); }} className={`flex-1 py-2 text-center rounded-xl text-xs font-bold transition-all ${activeTab === 'analytics' ? 'bg-[#70892E] text-white' : 'opacity-60 hover:opacity-100'}`}>גרפים ואנליזה</button>
          <button onClick={() => { setActiveTab('tools'); }} className={`flex-1 py-2 text-center rounded-xl text-xs font-bold transition-all ${activeTab === 'tools' ? 'bg-[#70892E] text-white' : 'opacity-60 hover:opacity-100'}`}>הוצאות ורכש</button>
        </div>

        {/* Dynamic Views Switcher */}
        {activeTab === 'dashboard' && (
          <DashboardView 
            clients={clientsWithAlerts} 
            totalRev={totalRevenue} 
            totalExpenses={totalExpenses} 
            netProfit={netProfit}
            annualGoal={annualGoal} 
            totalPaidRevenue={totalPaidRevenue}
            totalUnpaidRevenue={totalUnpaidRevenue}
            setActiveTab={setActiveTab}
            setSelectedClientId={setSelectedClientId}
          />
        )}

        {activeTab === 'clients' && (
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
            {/* List Side */}
            <div className={`lg:col-span-1 space-y-4 ${selectedClientId ? 'hidden lg:block' : 'block'}`}>
              <div className="bg-white/5 border border-white/10 rounded-3xl p-4 backdrop-blur-xl">
                <div className="flex justify-between items-center mb-3">
                  <h2 className="text-sm font-bold text-[#70892E]">רשימת הלקוחות שלך ({clients.length})</h2>
                  <button onClick={() => setIsAddClientOpen(true)} className="text-xs text-[#70892E] hover:underline flex items-center gap-1">
                    <Plus size={12} /> הוסף חדש
                  </button>
                </div>
                {/* Search Bar */}
                <div className="relative mb-3">
                  <input 
                    type="text" 
                    placeholder="חפש לקוח לפי שם, מיקום או טלפון..." 
                    value={searchQuery}
                    onChange={(e) => setSearchQuery(e.target.value)}
                    className="w-full bg-black/30 border border-white/10 rounded-xl py-2 px-3 pl-10 text-xs focus:outline-none focus:border-[#70892E] transition-all text-right"
                  />
                  <Search size={14} className="absolute left-3 top-2.5 opacity-40 text-white" />
                </div>

                <div className="space-y-2 max-h-[500px] overflow-y-auto pr-1">
                  {clientsWithAlerts
                    .filter(c => c.name.includes(searchQuery) || c.location.includes(searchQuery) || c.phone.includes(searchQuery))
                    .map(c => {
                      const clientTotalRev = c.visits.reduce((acc, v) => acc + v.cost, 0);
                      const outstandingDebts = c.visits.some(v => !v.paid);
                      return (
                        <div 
                          key={c.id} 
                          onClick={() => setSelectedClientId(c.id)}
                          className={`p-3 rounded-2xl border transition-all cursor-pointer flex justify-between items-center ${selectedClientId === c.id ? 'bg-[#70892E]/20 border-[#70892E]' : 'bg-white/5 border-white/5 hover:bg-white/10'}`}
                        >
                          <div className="space-y-1">
                            <p className="font-bold text-sm flex items-center gap-1.5">
                              {c.name}
                              {outstandingDebts && <span className="w-1.5 h-1.5 rounded-full bg-red-400" title="יש חוב פתוח" />}
                            </p>
                            <p className="text-[11px] opacity-60 flex items-center gap-1"><MapPin size={10}/> {c.location}</p>
                            <p className="text-[10px] font-bold text-[#70892E]">שווי שנתי: ₪{clientTotalRev.toLocaleString()}</p>
                          </div>
                          
                          <div className="flex items-center gap-2">
                            {/* Alert Indicator */}
                            <span className={`w-2.5 h-2.5 rounded-full ${c.alertLevel === 'red' ? 'bg-red-500 animate-pulse' : c.alertLevel === 'yellow' ? 'bg-yellow-500' : 'bg-green-500'}`} title={`רמת התראה: ${c.alertLevel}`} />
                            <ChevronRight size={16} className="opacity-40" />
                          </div>
                        </div>
                      );
                    })}
                </div>
              </div>
            </div>

            {/* Profile Detail Side */}
            <div className={`lg:col-span-2 ${selectedClientId ? 'block' : 'hidden lg:block'}`}>
              {selectedClient ? (
                <ClientLedgerView 
                  client={selectedClient} 
                  onBack={() => setSelectedClientId(null)}
                  onTogglePayment={(visitId) => handleTogglePaymentStatus(selectedClient.id, visitId)}
                  onOpenAddVisit={() => setIsAddVisitOpen(true)}
                  onOpenEditVisit={handleOpenEditVisit}
                  onDeleteVisit={(visitId) => handleDeleteVisit(selectedClient.id, visitId)}
                  onUpdateNotes={(type, text) => handleUpdateNotes(selectedClient.id, type, text)}
                  onSimulatePhoto={() => handleSimulatePhotoUpload(selectedClient.id)}
                  onUpdateFrequency={(freq) => handleUpdateFrequency(selectedClient.id, freq)}
                />
              ) : (
                <div className="bg-white/5 border border-white/10 rounded-3xl p-12 text-center backdrop-blur-xl flex flex-col items-center justify-center min-h-[400px]">
                  <Users size={48} className="text-[#70892E] opacity-30 mb-4" />
                  <h3 className="font-bold text-lg mb-1">בחר לקוח מהרשימה</h3>
                  <p className="text-xs opacity-60 max-w-sm">לחץ על לקוח כדי לפתוח את תיק הנכס המלא שלו, להוסיף או לערוך ביקורים, לעדכן תשלומים ולצפות ביומן המערכת החכם שלו.</p>
                </div>
              )}
            </div>
          </div>
        )}

        {activeTab === 'analytics' && (
          <AnalyticsDashboardView clients={clients} expenses={expenses} />
        )}

        {activeTab === 'tools' && (
          <ExpensesView expenses={expenses} setExpenses={setExpenses} />
        )}

      </main>

      {}
      {/* Mobile Sticky Navigation */}
      <nav className="fixed bottom-0 left-0 right-0 p-4 bg-[#053931]/90 backdrop-blur-2xl border-t border-white/10 z-40 md:hidden flex justify-around items-center">
        <button 
          onClick={() => { setActiveTab('dashboard'); setSelectedClientId(null); }} 
          className={`flex flex-col items-center gap-1 ${activeTab === 'dashboard' ? 'text-[#70892E]' : 'opacity-40'}`}
        >
          <LayoutDashboard size={20} />
          <span className="text-[10px]">הבורסה</span>
        </button>
        
        <button 
          onClick={() => { setActiveTab('clients'); }} 
          className={`flex flex-col items-center gap-1 ${activeTab === 'clients' ? 'text-[#70892E]' : 'opacity-40'}`}
        >
          <Users size={20} />
          <span className="text-[10px]">לקוחות</span>
        </button>

        {/* Dynamic Float Quick Add Button */}
        <button 
          onClick={() => setIsAddClientOpen(true)}
          className="w-12 h-12 -mt-6 bg-gradient-to-tr from-[#70892E] to-emerald-500 rounded-full flex items-center justify-center shadow-lg shadow-[#70892E]/40 text-white font-bold transform active:scale-95 transition-all"
        >
          <Plus size={24} />
        </button>

        <button 
          onClick={() => { setActiveTab('analytics'); }} 
