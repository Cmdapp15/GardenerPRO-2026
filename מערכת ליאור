      { id: 102, date: '2026-04-26', jobType: 'טיפול מונע למזיקים', cost: 350, paymentType: 'מזומן', paid: true, details: 'ריסוס נגד כנימות בוורדים.' },
      { id: 103, date: '2026-04-12', jobType: 'תחזוקה שוטפת', cost: 450, paymentType: 'העברה', paid: false, details: 'כיסוח דשא רגיל, נשאר חוב על סך 450 ש"ח שיסגר בביקור הבא.' }
